# 服务器配置
# 云平台（如 Render）通常会注入 PORT，应用会在 SERVER_PORT 未设置时自动使用 PORT。
SERVER_PORT=8080
SERVER_MODE=debug
CORS_ORIGIN=http://localhost:5173

# 数据库配置
# 支持的类型: mysql, postgres, mgdb
# postgres 用于 Supabase
DATABASE_TYPE=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=appdb
DATABASE_USER=root
DATABASE_PASS=your_password_here
# PostgreSQL 可选: disable / require / verify-ca / verify-full
DATABASE_SSL_MODE=disable

# Supabase Session Pooler 配置示例
# 注意: DATABASE_HOST 只能填主机名，不要带 https://
# DATABASE_TYPE=postgres
# DATABASE_HOST=aws-1-<region>.pooler.supabase.com
# DATABASE_PORT=5432
# DATABASE_NAME=postgres
# DATABASE_USER=postgres.<project-ref>
# DATABASE_PASS=your_supabase_password
# DATABASE_SSL_MODE=require

# JWT配置
JWT_SECRET=your-jwt-secret-key-change-in-production

# 签名与加密配置（开启后必须提供 16/24/32 字节 AES 密钥）
ENABLE_SIGNATURE=false
SIGNATURE_SECRET=your-api-signing-secret-change-me
ENCRYPTION_AES_KEY=

# Redis 配置（用于验证码缓存）
# Redis Cloud 示例:
# REDIS_ADDR=redis-11366.c252.ap-southeast-1-1.ec2.cloud.redislabs.com:11366
# REDIS_USERNAME=default
# REDIS_PASSWORD=DqGlP8eflTUaNEejpSbbowcSiXs0D6CO
# REDIS_DB=0
# REDIS_TLS=true
# REDIS_KEY_PREFIX=captcha:

# Kafka 配置（Aiven mTLS 示例）
# KAFKA_BROKERS=kafka-xxxx.aivencloud.com:18614
# KAFKA_TOPIC=test-topic
# KAFKA_SECURITY_PROTOCOL=SSL
# KAFKA_SSL_CA_FILE=./certs/kafka/ca.pem
# KAFKA_SSL_CERT_FILE=./certs/kafka/service.cert
# KAFKA_SSL_KEY_FILE=./certs/kafka/service.key

# Supabase 配置 (前端使用)
# SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
